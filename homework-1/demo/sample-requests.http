#!/usr/bin/env zsh
set -euo pipefail

SCRIPT_DIR=${0:A:h}
DATA_FILE="${SAMPLE_DATA_FILE:-$SCRIPT_DIR/sample-data.json}"
APP_URL="${APP_URL:-http://127.0.0.1:8080}"
CURL_BIN="${CURL_BIN:-/usr/bin/curl}"
CAT_BIN="${CAT_BIN:-/bin/cat}"

json_get() {
  local key_path="$1"
  python3 - "$DATA_FILE" "$key_path" <<'PY'
import json
import sys

data_file = sys.argv[1]
key_path = sys.argv[2]

with open(data_file, "r", encoding="utf-8") as fh:
    data = json.load(fh)

current = data
for part in key_path.split("."):
    current = current[part]

if isinstance(current, (dict, list)):
    print(json.dumps(current, separators=(",", ":")))
else:
    print(str(current))
PY
}

request() {
  local method="$1"
  local path="$2"
  local expected_code="$3"
  local body="${4:-}"
  local response_file="$5"
  local code

  echo ""
  echo ">>> $method $APP_URL$path (expected: $expected_code)"
  if [[ -n "$body" ]]; then
    echo ">>> request-body: $body"
  fi

  if [[ -n "$body" ]]; then
    code=$("$CURL_BIN" -sS -o "$response_file" -w "%{http_code}" \
      -X "$method" \
      -H "Content-Type: application/json" \
      --data "$body" \
      "$APP_URL$path")
  else
    code=$("$CURL_BIN" -sS -o "$response_file" -w "%{http_code}" \
      -X "$method" \
      "$APP_URL$path")
  fi

  echo "<<< status: $code"
  if [[ -s "$response_file" ]]; then
    echo "<<< response-body:"
    "$CAT_BIN" "$response_file"
    echo ""
  else
    echo "<<< response-body: <empty>"
  fi

  if [[ "$code" != "$expected_code" ]]; then
    echo "Request failed: $method $path (expected $expected_code, got $code)" >&2
    return 1
  fi
}

json_field() {
  local file="$1"
  local field="$2"
  python3 - "$file" "$field" <<'PY'
import json
import sys

response_file = sys.argv[1]
field = sys.argv[2]

with open(response_file, "r", encoding="utf-8") as fh:
    data = json.load(fh)

print(data[field])
PY
}

assert_json_field_equals() {
  local file="$1"
  local field="$2"
  local expected="$3"
  local actual
  actual=$(json_field "$file" "$field")
  if [[ "$actual" != "$expected" ]]; then
    echo "Assertion failed for $field in $file: expected '$expected', got '$actual'" >&2
    return 1
  fi
}

assert_json_array_ids_equals() {
  local file="$1"
  local expected_json_array="$2"
  python3 - "$file" "$expected_json_array" <<'PY'
import json
import sys

response_file = sys.argv[1]
expected_json_array = sys.argv[2]

with open(response_file, "r", encoding="utf-8") as fh:
    data = json.load(fh)

expected = json.loads(expected_json_array)
actual = [item["id"] for item in data]

if actual != expected:
    raise SystemExit(f"Assertion failed for array ids in {response_file}: expected {expected}, got {actual}")
PY
}

assert_json_array_length() {
  local file="$1"
  local expected_length="$2"
  python3 - "$file" "$expected_length" <<'PY'
import json
import sys

response_file = sys.argv[1]
expected_length = int(sys.argv[2])

with open(response_file, "r", encoding="utf-8") as fh:
    data = json.load(fh)

actual_length = len(data)
if actual_length != expected_length:
    raise SystemExit(
        f"Assertion failed for array length in {response_file}: expected {expected_length}, got {actual_length}"
    )
PY
}

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

echo "Running API calls against $APP_URL"

deposit_payload=$(json_get "payloads.createDeposit")
transfer_payload=$(json_get "payloads.createTransfer")
withdrawal_payload=$(json_get "payloads.createWithdrawal")
insufficient_withdrawal_payload=$(json_get "payloads.createInsufficientWithdrawal")
status_override_payload=$(json_get "payloads.createWithClientStatus")
invalid_payload=$(json_get "payloads.invalidTransaction")

account_id=$(json_get "filters.accountId")
type_filter=$(json_get "filters.type")
from_filter=$(json_get "filters.from")
to_filter=$(json_get "filters.to")
missing_transaction_id=$(json_get "lookups.missingTransactionId")
invalid_account_id=$(json_get "lookups.invalidAccountId")
summary_empty_account_id=$(json_get "lookups.summaryEmptyAccountId")

request "POST" "/transactions" "201" "$deposit_payload" "$tmpdir/create-deposit.json"
deposit_id=$(json_field "$tmpdir/create-deposit.json" "id")
assert_json_field_equals "$tmpdir/create-deposit.json" "status" "COMPLETED"

request "POST" "/transactions" "201" "$status_override_payload" "$tmpdir/create-with-client-status.json"
status_override_id=$(json_field "$tmpdir/create-with-client-status.json" "id")
assert_json_field_equals "$tmpdir/create-with-client-status.json" "status" "COMPLETED"

request "POST" "/transactions" "201" "$transfer_payload" "$tmpdir/create-transfer.json"
transfer_id=$(json_field "$tmpdir/create-transfer.json" "id")
assert_json_field_equals "$tmpdir/create-transfer.json" "status" "COMPLETED"

request "POST" "/transactions" "201" "$withdrawal_payload" "$tmpdir/create-withdrawal.json"
withdrawal_id=$(json_field "$tmpdir/create-withdrawal.json" "id")
assert_json_field_equals "$tmpdir/create-withdrawal.json" "status" "COMPLETED"

request "POST" "/transactions" "201" "$insufficient_withdrawal_payload" "$tmpdir/create-insufficient-withdrawal.json"
failed_withdrawal_id=$(json_field "$tmpdir/create-insufficient-withdrawal.json" "id")
assert_json_field_equals "$tmpdir/create-insufficient-withdrawal.json" "status" "FAILED"

request "GET" "/transactions" "200" "" "$tmpdir/list-all.json"
request "GET" "/transactions/$transfer_id" "200" "" "$tmpdir/get-by-id.json"
request "GET" "/transactions/$failed_withdrawal_id" "200" "" "$tmpdir/get-failed-by-id.json"
assert_json_field_equals "$tmpdir/get-failed-by-id.json" "status" "FAILED"
request "GET" "/accounts/$account_id/summary" "200" "" "$tmpdir/account-summary.json"
assert_json_array_ids_equals \
  "$tmpdir/account-summary.json" \
  "[\"$failed_withdrawal_id\",\"$withdrawal_id\",\"$transfer_id\",\"$status_override_id\",\"$deposit_id\"]"
request "GET" "/accounts/$summary_empty_account_id/summary" "200" "" "$tmpdir/account-summary-empty.json"
assert_json_array_length "$tmpdir/account-summary-empty.json" "0"

request "GET" "/transactions?accountId=$account_id" "200" "" "$tmpdir/list-by-account.json"
request "GET" "/transactions?type=$type_filter" "200" "" "$tmpdir/list-by-type.json"
request "GET" "/transactions?from=$from_filter&to=$to_filter" "200" "" "$tmpdir/list-by-date-range.json"
request "GET" "/transactions?accountId=$account_id&type=$type_filter&from=$from_filter&to=$to_filter" "200" "" "$tmpdir/list-combined-filters.json"

request "GET" "/accounts/$account_id/balance" "200" "" "$tmpdir/balance.json"

request "POST" "/transactions" "400" "$invalid_payload" "$tmpdir/invalid-create.json"
request "GET" "/transactions/$missing_transaction_id" "404" "" "$tmpdir/missing-by-id.json"
request "GET" "/accounts/$invalid_account_id/balance" "400" "" "$tmpdir/invalid-balance-account.json"
request "GET" "/accounts/$invalid_account_id/summary" "400" "" "$tmpdir/invalid-summary-account.json"

echo "All API calls completed successfully."
